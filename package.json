{
  "name": "tena-forge",
  "private": true,
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "lint:web": "npm --workspace apps/web run lint",
    "dev:mobile": "cd apps/mobile && flutter run",
    "analyze:mobile": "cd apps/mobile && flutter analyze",
    "worker:dev": "cd apps/worker && python -m uvicorn main:app --reload --host 0.0.0.0 --port 8100",
    "typecheck": "npm --workspace apps/web run typecheck"
  }
}
